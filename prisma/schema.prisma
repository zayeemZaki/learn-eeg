// EEG Practice Center — data model.
//
// Design notes:
//  - User/Account/Session/VerificationToken are the shapes Auth.js's Prisma
//    adapter expects. We extend User with domain fields (position, institution,
//    passwordHash) so credentials auth and profile data live in one place.
//  - Content (Question/Choice/AtlasEntry) is modelled as *seedable* data, kept
//    separate from app logic. An author/admin pipeline can write to these tables
//    without touching the rest of the system.
//  - Attempt is the only write-heavy table (one row per answered question) and
//    is the source of truth for a user's progress.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Position {
  MEDICAL_STUDENT
  RESIDENT
  ATTENDING_NEUROLOGIST
}

// Access tier. Additive with a USER default so every existing row remains valid
// without backfill; the first ADMIN is minted out-of-band (scripts/make-admin.ts).
enum Role {
  USER
  ADMIN
}

enum AtlasCategory {
  NORMAL_VARIANT
  ABNORMAL_VARIANT
}

// Clinical topic a question belongs to. Additive with an OTHER default so every
// existing Question row stays valid without a data backfill — the migration's
// column default sets all prior rows to OTHER. Used for per-category analytics
// (M3) and admin authoring; distinct from AtlasCategory, which classifies atlas
// images, not questions.
enum QuestionCategory {
  NORMAL_VARIANT
  EPILEPTIFORM
  SEIZURE
  ARTIFACT
  ENCEPHALOPATHY
  FOCAL
  OTHER
}

// ── Auth + profile ────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  position     Position
  institution  String
  role         Role      @default(USER)
  image        String?
  // Reserved for future OAuth verification; unused by the credentials flow.
  emailVerified DateTime?

  accounts Account[]
  sessions Session[]
  attempts Attempt[]
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Forgot-password flow (M6). One row per outstanding reset request. We store
// only the SHA-256 HASH of the token, never the raw value — a DB leak can't be
// turned into a working reset link. Tokens are single-use (usedAt) and
// time-limited (expiresAt); prior unused tokens for a user are deleted when a
// new one is issued and when one is consumed, so at most one is ever live.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Auth.js adapter models. Present so OAuth providers can be added later
// without a migration; the credentials + JWT flow does not populate them.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Question bank ───────────────────────────────────────────────────────────

model Question {
  id          String           @id @default(cuid())
  stem        String           // the clinical prompt
  explanation String           // teaching point shown after answering
  // DEPRECATED: superseded by the `images` relation (one-to-many QuestionImage).
  // Kept this pass as a back-compat mirror so existing data survives the migration;
  // a later pass backfills, stops reading it, then drops the column. New questions
  // leave this null — author images via QuestionImage instead.
  imageUrl    String?          // optional EEG trace (deprecated — see `images`)
  difficulty  Int              @default(1) // 1=easy ... 3=hard
  category    QuestionCategory @default(OTHER) // clinical topic; OTHER for legacy rows

  choices  Choice[]
  images   QuestionImage[]
  attempts Attempt[]

  createdAt DateTime @default(now())

  @@index([category])
}

// One EEG image attached to a Question. A question can carry several (gallery +
// lightbox on the answer screen); `position` gives them a stable author-defined
// order. Cascade-on-delete mirrors Choice — deleting a Question removes its image
// rows in the same DB cascade (the Blob objects are cleaned up separately by the
// delete/update actions, since the DB cascade never touches Blob storage).
model QuestionImage {
  id         String   @id @default(cuid())
  questionId String
  url        String
  alt        String?  // per-image description for screen readers (gallery + lightbox)
  position   Int      @default(0) // explicit, stable ordering (0-based)
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Choice {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)

  question Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attempts Attempt[]

  @@index([questionId])
}

model Attempt {
  id               String   @id @default(cuid())
  userId           String
  questionId       String
  selectedChoiceId String
  isCorrect        Boolean
  createdAt        DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedChoice Choice   @relation(fields: [selectedChoiceId], references: [id])

  @@index([userId])
  @@index([questionId])
}

// ── EEG atlas ─────────────────────────────────────────────────────────────────

model AtlasEntry {
  id          String        @id @default(cuid())
  title       String
  category    AtlasCategory
  description String
  imageUrl    String

  createdAt DateTime @default(now())

  @@index([category])
}
