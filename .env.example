# Neon Postgres connection string (from the Neon Connect panel).
# Use the DIRECT (unpooled) URL — host WITHOUT "-pooler" — so Prisma
# migrations work; the pooled URL only matters for serverless runtimes.
DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/<dbname>?sslmode=require"

# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="replace-me"

# Optional: enables caching of the PubMed literature feed.
# If unset, the feed is fetched live on every request.
REDIS_URL="redis://localhost:6379"

# Optional: raises PubMed E-utilities rate limit from 3 to 10 req/sec.
# https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=""

# Optional: enables admin EEG image uploads to Vercel Blob.
# Vercel dashboard → Storage → Blob → create store → copy token.
# Without it the app still boots; admin uploads return a clear error.
BLOB_READ_WRITE_TOKEN=""
